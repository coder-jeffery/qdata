# 复制为 .env 后按需修改

# 数据源：单一名 | auto | 逗号链（联调可用 auto）
# 可选 historical: akshare, baostock, tushare, joinquant, efinance, mootdx, zvt, miniqmt
QDATA_DATA_SOURCE=auto
QDATA_DATA_SOURCE_CHAIN=akshare,baostock,tushare,joinquant,efinance,mootdx

# ---- M1.5 生产主源（禁止 auto；全市场回填强制 MAX_SYMBOLS=0）----
QDATA_PROD_SOURCE=baostock
QDATA_PROD_MIN_UNIVERSE=500
QDATA_AKSHARE_MAX_SYMBOLS=0

# 联调冒烟可临时：QDATA_AKSHARE_MAX_SYMBOLS=30（生产作业会强制改回 0）

# Tushare Pro（默认关闭；生产主源选 tushare 时必须开启）
QDATA_TUSHARE_ENABLED=false
# QDATA_TUSHARE_TOKEN=你的token
# QDATA_TUSHARE_RATE_LIMIT=200

# JoinQuant 聚宽（默认关闭；需 jqdatasdk + 账号；须先申请 JQData）
# 申请：https://www.joinquant.com/default/index/sdk
# USER=申请时的 11 位手机号；PASSWORD=官网登录密码（新用户默认可为手机号后 6 位）
# 推荐用于 daily_basic / suspend / fin_statement 全量+增量：
#   python -m qdata.jobs.sync_market_extras --source joinquant --mode full --start … --end …
#   python -m qdata.jobs.sync_market_extras --source joinquant --mode incremental
# 日批 --with-extras / cron 使用的 extras 源（默认 joinquant，不改生产主源）
QDATA_EXTRAS_SOURCE=joinquant
QDATA_JOINQUANT_ENABLED=false
# QDATA_JOINQUANT_USER=13800138000
# QDATA_JOINQUANT_PASSWORD=你的密码
# QDATA_JOINQUANT_RATE_LIMIT=60

# MootDX / 通达信（可选）
# QDATA_MOOTDX_SERVER=110.41.147.114:7709
# QDATA_TDX_DIR=/path/to/new_tdx

# EasyQuotation
# QDATA_EASYQUOTATION_BACKEND=sina

# 交易通道：paper（默认纸交易）| miniqmt | easytrader
QDATA_BROKER=paper
QDATA_PAPER_INITIAL_CASH=1000000
# MiniQMT（需本机 QMT + xtquant）
# QDATA_BROKER=miniqmt
# QDATA_MINIQMT_PATH=/path/to/userdata_mini
# QDATA_MINIQMT_ACCOUNT=你的资金账号

# EasyTrader（需本机交易客户端）
# QDATA_BROKER=easytrader
# QDATA_EASYTRADER_BROKER=universal_client
# QDATA_EASYTRADER_USER=
# QDATA_EASYTRADER_PASSWORD=
# QDATA_EASYTRADER_EXE=

# 告警 webhook（钉钉/企微机器人，日批成功/失败通知）
# QDATA_ALERT_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=...

QDATA_CH_HOST=localhost
QDATA_CH_PORT=8123
QDATA_CH_DATABASE=qdata
QDATA_CH_USER=default
# 本地 devops/clickhouse 默认密码见 devops/clickhouse/config/users.xml
QDATA_CH_PASSWORD=quant123456
